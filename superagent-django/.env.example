# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourapp.railway.app

# ── Database (Railway injects this automatically when you add Postgres) ──────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis (Railway injects this automatically when you add Redis) ────────────
REDIS_URL=redis://default:password@host:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourmobileapp.com
CORS_ALLOW_ALL_ORIGINS=False

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# ── AI / Groq ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email (optional) ─────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_ALWAYS_EAGER=False

# ── Django settings module ───────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=superagent.settings.production

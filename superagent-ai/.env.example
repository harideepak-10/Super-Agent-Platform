# ============================================================
# Super Agent AI Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Groq LLM (required for production agent runs)
# Get your key at: https://console.groq.com
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# Gmail OAuth2 (required for Gmail tools)
# Set up at: https://console.cloud.google.com
# Steps:
#   1. Create a project and enable the Gmail API
#   2. Create OAuth2 credentials (Desktop app)
#   3. Run the OAuth consent flow once to get a refresh token
# ------------------------------------------------------------
GMAIL_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# ------------------------------------------------------------
# JWT Authentication (required for the API)
# Generate a secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
JWT_SECRET_KEY=replace_with_a_random_64_char_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# API User Credentials
# Generate a password hash:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
# ------------------------------------------------------------
API_USERNAME=admin
API_PASSWORD_HASH=$2b$12$examplehashreplacethiswithrealbcrypthash

# ------------------------------------------------------------
# CORS (optional — defaults to * for local dev)
# In production, restrict to your frontend domain:
#   CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com
# ------------------------------------------------------------
CORS_ORIGINS=*

            "body": { "mode": "raw", "raw": "{\n  \"email\": \"colleague@example.com\",\n  \"role\": \"member\"\n}" },
            "description": "Invite a user who already has an account. No email sent — they see it in-app via GET /team/invites/. Roles: owner, admin, member, viewer."

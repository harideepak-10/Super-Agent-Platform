    {
      "name": "14 - WebSockets",
      "item": [
        {
          "name": "WS — Task Live Stream",
          "request": {
            "method": "GET",
            "url": "wss://super-agent-platform.onrender.com/ws/tasks/{{task_id}}/",
            "description": "Connect after creating a task to receive real-time step-by-step updates.\n\nAuth: Add header  Authorization: Bearer {{token}}\nKeep-alive: send {\"type\": \"ping\"} → server replies {\"type\": \"pong\"}\n\n── STANDARDISED EVENT ENVELOPE ──\nEvery event has this shape:\n{\n  \"event\":      \"<event_name>\",\n  \"task_id\":    \"<uuid>\",\n  \"agent_name\": \"Email Agent\",\n  \"step\":       3,\n  \"title\":      \"Sending email\",\n  \"detail\":     \"To harideepak@krypsos.tech\",\n  \"data\":       { ...raw details... }\n}\nstatus_changed events also include: \"status\": \"completed|failed|waiting_approval\"\n\n── EVENT NAMES ──\n  step_started    — LLM thinking OR tool about to run\n  step_finished   — tool result received\n  status_changed  — task status changed (approval_needed / completed / failed)\n  step_output     — partial streaming output (reserved for future use)\n\n── EXAMPLE EVENTS ──\nstep_started (thinking):\n  { \"event\": \"step_started\", \"title\": \"Thinking\", \"detail\": \"Planning next action (step 1)\" }\n\nstep_started (tool call):\n  { \"event\": \"step_started\", \"title\": \"Sending email\", \"detail\": \"To harideepak@krypsos.tech\" }\n\nstep_finished:\n  { \"event\": \"step_finished\", \"title\": \"Got result\", \"detail\": \"Sending email completed\" }\n\nstatus_changed (approval needed):\n  { \"event\": \"status_changed\", \"status\": \"waiting_approval\", \"title\": \"Waiting for approval\", \"detail\": \"Send Email requires your review\" }\n\nstatus_changed (completed):\n  { \"event\": \"status_changed\", \"status\": \"completed\", \"title\": \"Task complete\", \"detail\": \"<result preview>\" }\n\nTypical use: connect immediately after POST /tasks/create/, use title+detail to drive UI labels, use status_changed to update progress bar and status chip."
          }
        },
        {
          "name": "WS — Notifications Stream",
          "request": {
            "method": "GET",
            "url": "wss://super-agent-platform.onrender.com/ws/notifications/",
            "description": "Personal notification channel — one connection per logged-in user.\n\nAuth: Add header  Authorization: Bearer {{token}}\n\nEvents received:\n  connected    — handshake confirmed\n  notification — new notification pushed, contains full notification object in 'data'\n\nNotification types in data:\n  task_complete     — agent finished a task\n  task_failed       — agent task failed\n  approval_needed   — agent needs your approval\n  approval_decided  — your approval was approved or rejected\n  team_invite       — someone invited you to a workspace\n\nKeep-alive: send {\"type\": \"ping\"} → server replies {\"type\": \"pong\"}\n\nTypical use: connect on app launch, update notification badge count in real-time without polling."
          }
        },
        {
          "name": "WS — Agent Live Stream",
          "request": {
            "method": "GET",
            "url": "wss://super-agent-platform.onrender.com/ws/agents/{{agent_id}}/live/",
            "description": "Streams live thought / action / observation events for a specific agent.\n\nAuth: Add header  Authorization: Bearer {{token}}\n\nEvents received:\n  connected    — handshake confirmed\n  agent_event  — thought, tool call, or observation from the running agent\n\nKeep-alive: send {\"type\": \"ping\"} → server replies {\"type\": \"pong\"}\n\nTypical use: power the Agent Live Activity screen — show what the agent is thinking and doing right now."
          }
        }
      ]
    }
  ]
}

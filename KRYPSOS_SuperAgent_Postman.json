    {
      "name": "12 - Search",
      "item": [
        {
          "name": "Global Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search/?q=send email",
              "query": [{ "key": "q", "value": "send email", "description": "All words must appear — 'send email' returns results that contain BOTH 'send' AND 'email' as whole words" }]
            },
            "description": "Searches tasks (prompt, result, agent name), agents (name, type, description), and audit events simultaneously. Returns grouped results with count per group.\n\nWhole-word AND matching: 'send email' finds entries containing both words. 'read' will NOT match 'ready' or 'already'."
          }
        },
        {
          "name": "Search Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search/tasks/?q=send email",
              "query": [
                { "key": "q", "value": "send email", "description": "All words must appear — 'send email' finds tasks containing BOTH 'send' AND 'email' as whole words in prompt/result/agent name/status" },
                { "key": "status", "value": "failed", "description": "Optional: completed | failed | running | waiting_approval", "disabled": true }
              ]
            },
            "description": "Search tasks by keyword. Multi-word queries use AND — 'send email' finds tasks that contain both words.\n\nWhole-word matching: 'read' matches 'Read my emails' but NOT 'Q2 report ready'."
          }
        },
        {
          "name": "Search Agents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search/agents/?q=email agent",
              "query": [
                { "key": "q", "value": "email agent", "description": "All words must appear — 'email agent' finds agents whose name/type/description contain BOTH words" }
              ]
            },
            "description": "Search agents by keyword. Multi-word queries use AND — 'email agent' finds agents that contain both words across name, agent_type, and description.\n\nWhole-word matching: 'email' matches 'Email Agent' but NOT 'emailagent'."
          }
        }
      ]
    },

    {
      "name": "10 - Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/notifications/",
              "query": [
                { "key": "unread", "value": "true", "description": "Pass 'true' to return only unread notifications", "disabled": true }
              ]
            },
            "description": "Returns up to 50 notifications for the logged-in user, newest first.\n\nNotification types:\n  task_complete — agent finished a task\n  task_failed — agent task failed or approval rejected\n  approval_needed — agent is waiting for your approval\n  approval_decided — your approval was approved or rejected by a reviewer\n  team_invite — someone invited you to a workspace\n  budget_alert — spending near the limit\n  integration_error — connected app has an issue"
          }
        },
        {
          "name": "List Unread Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/notifications/?unread=true",
              "query": [
                { "key": "unread", "value": "true" }
              ]
            },
            "description": "Returns only unread notifications."
          }
        },
        {
          "name": "Get Notification",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('notification_id', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications/{{notification_id}}/",
            "description": "Get a single notification detail."
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/notifications/{{notification_id}}/",
            "description": "Mark a single notification as read. Call this when the user opens/taps a notification. Sets is_read=true and saves read_at timestamp. No body required."
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/notifications/{{notification_id}}/",
            "description": "Permanently delete a single notification."
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/notifications/mark-all-read/",
            "body": { "mode": "raw", "raw": "{}" },
            "description": "Mark all notifications as read at once. Call when user opens the notifications screen."
          }
        },
        {
          "name": "Get Notification Settings",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications/settings/",
            "description": "Get the user's notification preferences."
          }
        },
        {
          "name": "Update Notification Settings",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/notifications/settings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_on_task_complete\": true,\n  \"email_on_task_failed\": true,\n  \"email_on_approval_needed\": true,\n  \"email_on_budget_alert\": true,\n  \"push_enabled\": true\n}"
            },
            "description": "Toggle which notification types the user receives. All fields are optional — send only what you want to change."
          }
        }
      ]
    },

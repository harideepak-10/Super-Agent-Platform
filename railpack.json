{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "install": {
      "commands": [
        "pip install -r superagent-django/requirements/production.txt"
      ]
    },
    "build": {
      "commands": [
        "cd superagent-django && python manage.py collectstatic --noinput"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd superagent-django && python manage.py migrate --noinput && gunicorn superagent.wsgi:application --bind 0.0.0.0:$PORT --workers 2 --timeout 120",
    "variables": {
      "PYTHONPATH": "/app/superagent-django",
      "DJANGO_SETTINGS_MODULE": "superagent.settings.production"
    }
  }
}
